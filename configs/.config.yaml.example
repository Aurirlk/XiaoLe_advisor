# ============================================================
# 小乐AI · 高考志愿填报助手 — 用户配置
# ============================================================
# 只需修改 selected_module 选择模型，填写 API Key 即可。
# 预设详情在 llm_config.yaml / asr_config.yaml / tts_config.yaml / vllm_config.yaml 中。
# ============================================================

# ==================== 模块选择 ====================
selected_module:
  LLM: deepseek-v4-flash       # 大模型
  ASR: FunASR                   # 语音识别
  TTS: EdgeTTS                  # 语音合成
  VLLM: glm-4v-flash            # 视觉大模型

# ==================== API Key ====================
# 支持 ${ENV_VAR} 从环境变量读取，也可直接填写
# 不用的供应商留空即可
api_keys:
  # ── LLM / VLLM ────────────────────────────────────────
  DEEPSEEK_API_KEY: "${DEEPSEEK_API_KEY}"
  DASHSCOPE_API_KEY: "${DASHSCOPE_API_KEY}"
  ZHIPU_API_KEY: "${ZHIPU_API_KEY}"
  DOUBAO_API_KEY: "${DOUBAO_API_KEY}"
  MOONSHOT_API_KEY: "${MOONSHOT_API_KEY}"
  OPENAI_API_KEY: "${OPENAI_API_KEY}"
  MINIMAX_API_KEY: "${MINIMAX_API_KEY}"
  GROQ_API_KEY: "${GROQ_API_KEY}"

  # ── ASR / TTS 通用 ─────────────────────────────────────
  SILICONFLOW_API_KEY: "${SILICONFLOW_API_KEY}"
  DOUBAO_APPID: "${DOUBAO_APPID}"
  DOUBAO_ACCESS_TOKEN: "${DOUBAO_ACCESS_TOKEN}"
  TENCENT_APPID: "${TENCENT_APPID}"
  TENCENT_SECRET_ID: "${TENCENT_SECRET_ID}"
  TENCENT_SECRET_KEY: "${TENCENT_SECRET_KEY}"

  # ── ASR 专用 ───────────────────────────────────────────
  BAIDU_APP_ID: "${BAIDU_APP_ID}"
  BAIDU_API_KEY: "${BAIDU_API_KEY}"
  BAIDU_SECRET_KEY: "${BAIDU_SECRET_KEY}"
  XUNFEI_APP_ID: "${XUNFEI_APP_ID}"
  XUNFEI_API_KEY: "${XUNFEI_API_KEY}"
  XUNFEI_API_SECRET: "${XUNFEI_API_SECRET}"

  # ── TTS 专用 ───────────────────────────────────────────
  ALIYUN_APPKEY: "${ALIYUN_APPKEY}"
  ALIYUN_TOKEN: "${ALIYUN_TOKEN}"
  ALIYUN_ACCESS_KEY_ID: "${ALIYUN_ACCESS_KEY_ID}"
  ALIYUN_ACCESS_KEY_SECRET: "${ALIYUN_ACCESS_KEY_SECRET}"
  MINIMAX_GROUP_ID: "${MINIMAX_GROUP_ID}"
  FISH_SPEECH_API_KEY: "${FISH_SPEECH_API_KEY}"

  # ── 联网搜索 ───────────────────────────────────────────
  METASO_API_KEY: "${METASO_API_KEY}"
  TAVILY_API_KEY: "${TAVILY_API_KEY}"

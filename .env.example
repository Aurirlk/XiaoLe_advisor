# ============================================================
# 小乐AI · 高考志愿填报助手 — 环境变量配置
# ============================================================
# 复制为 .env 后填写（.env 不要提交到 GitHub）
# .config.yaml 中的 api_keys 优先读取此文件中的值
# 不用的供应商留空即可
# ============================================================

# ── LLM API Key ──────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-key-here
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
DOUBAO_API_KEY=
MOONSHOT_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=
GROQ_API_KEY=

# ── ASR / TTS 通用（豆包/腾讯）──────────────────────────
SILICONFLOW_API_KEY=
DOUBAO_APPID=
DOUBAO_ACCESS_TOKEN=
TENCENT_APPID=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# ── ASR 专用（百度/讯飞）─────────────────────────────────
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=

# ── TTS 专用（阿里/MiniMax/FishSpeech）──────────────────
ALIYUN_APPKEY=
ALIYUN_TOKEN=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
MINIMAX_GROUP_ID=
FISH_SPEECH_API_KEY=

# ── 联网搜索 ─────────────────────────────────────────────
# DuckDuckGo 免费无需 Key，以下为可选付费搜索源
# 秘塔搜索申请：https://metaso.cn/search-api/api-keys
METASO_API_KEY=
# Tavily 申请：https://app.tavily.com/home
TAVILY_API_KEY=

# ── 管理员 API Key（保护 admin/rag 写入端点）─────────────
ADMIN_API_KEY=

# ── 数据库（不配置则使用 SQLite）────────────────────────
# POSTGRES_PASSWORD=your_password

# ── Redis / Celery ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# ── 服务端口 ─────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
# UI_HOST=127.0.0.1
# UI_PORT=5000
# UI_API_BASE_URL=http://127.0.0.1:8000
# AUTO_OPEN_UI=1
# RELOAD=1

# ── 其他 ─────────────────────────────────────────────────
# HF_ENDPOINT=https://hf-mirror.com
# WEB_SEARCH_CACHE_TTL_HOURS=24
# WEB_SEARCH_ENABLE_FETCH=1
# CORS_ALLOW_ORIGINS=*
# CHECKPOINT_BACKEND=memory
